# ─────────────────────────────────────────────────────
# PKL Court Connect — Environment Configuration
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.

# ── Database ──────────────────────────────────────────
DATABASE_URL=mysql://root:your_password@localhost:3306/pkl_court_connect

# ── Auth / JWT ────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
VITE_APP_ID=pkl-court-connect

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OAuth (social login) ─────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# ── Google Maps ───────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# ── Mapbox ────────────────────────────────────────────
# https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=

# ── Forge API (Maps/LLM/Voice proxy) ─────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Stripe (Payments) ────────────────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_ANNUAL_PRICE_ID=

# ── App URL ──────────────────────────────────────────
APP_BASE_URL=

# ── Firebase (Push Notifications) ────────────────────
# https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── Web Push (VAPID keys) ────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@pklcourtconnect.com

# ── Email (SMTP via Nodemailer) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
