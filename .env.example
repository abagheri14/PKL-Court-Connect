# ══════════════════════════════════════════════════════════════════════════════
# PKL Court Connect — Environment Configuration
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in real values before starting the app.
#   cp .env.example .env
#
# Variables prefixed with VITE_ are exposed to the browser client.
# All others are server-side only.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (MySQL 8.x) ─────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:your_password@localhost:3306/pkl_court_connect

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-this-to-a-secure-random-string
VITE_APP_ID=pkl-court-connect

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# CORS_ORIGIN=https://yourdomain.com  # Set in production for Socket.io CORS

# ── OAuth (social login — optional) ──────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# ── Google Maps (optional — for map features) ────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=

# ── Mapbox (REQUIRED — for map features) ─────────────────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.YOUR_MAPBOX_ACCESS_TOKEN_HERE

# ── Forge API (Maps/LLM/Voice proxy — optional) ──────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ── Stripe (Payments — optional for premium features) ────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_MONTHLY_PRICE_ID=price_YOUR_MONTHLY_PRICE_ID
STRIPE_ANNUAL_PRICE_ID=price_YOUR_ANNUAL_PRICE_ID

# ── Firebase (Push Notifications — optional) ─────────────────────────────────
# Get from: https://console.firebase.google.com → Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── Web Push (VAPID — server-side push, alternative to Firebase) ─────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@pklcourtconnect.com

# ── Email (SMTP via Nodemailer — for password resets, verification) ──────────
# For Gmail: enable 2FA, then create an App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM="PKL Court Connect <noreply@pklcourtconnect.com>"


# ── App URL (required for Stripe redirect URLs) ───────
APP_BASE_URL=

# ── Mapbox ────────────────────────────────────────────
VITE_MAPBOX_TOKEN=

# ── Firebase (Push Notifications) ────────────────────
# https://console.firebase.google.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# ── Web Push (VAPID keys) ────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@pklcourtconnect.com

# ── Email (SMTP via Nodemailer) ──────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
